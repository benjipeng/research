---
interface Props {
  tl?: string;
  tr?: string;
  bl?: string;
}
const { tl = 'Research by AppCubic', tr = 'B. Peng, Ph.D.', bl = 'EXC 488 · EM 509 NM' } = Astro.props;
---
<div class="chrome" aria-hidden="true">
  <span class="c tl">{tl}</span>
  <span class="c tr">{tr}</span>
  <span class="c bl">{bl}</span>
  <span class="c br">Local <b id="clock">00:00:00</b></span>
</div>
<style>
  .chrome { position: fixed; inset: 0; z-index: 60; pointer-events: none; }
  .chrome .c {
    position: absolute;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--dim);
    transition: opacity 0.5s;
  }
  .chrome .tl { top: 20px; left: 24px; }
  .chrome .tr { top: 20px; right: 24px; }
  .chrome .bl { bottom: 18px; left: 24px; }
  .chrome .br { bottom: 18px; right: 24px; }
  .chrome .br b { color: var(--bone); font-weight: 500; font-variant-numeric: tabular-nums; }
  .chrome::before, .chrome::after {
    content: ""; position: absolute; left: 0; right: 0; height: 1px;
    background: rgba(232, 230, 221, 0.22);
  }
  .chrome::before { top: 0; }
  .chrome::after { bottom: 0; }
</style>
<script>
  (function () {
    const el = document.getElementById('clock');
    if (!el) return;
    const t = () => { el.textContent = new Date().toLocaleTimeString('en-GB', { hour12: false }); };
    t(); setInterval(t, 1000);
  })();
</script>
